# ============================================================
# 🦞 OpenClaw Docker — Environment Variables
# ============================================================
# Copy this file:  cp .env.example .env
# Then fill in YOUR real values below.
# ============================================================

# ── §5 模型管理 (Model Management) ──────────────────────────
# Primary LLM provider API key (pick ONE or more)
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENROUTER_API_KEY=sk-or-your-key-here

# Azure OpenAI (if using Azure instead of OpenAI direct)
# AZURE_OPENAI_ENABLED=true
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-5-chat
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
# ── §4 聊天平台接入 — Discord ───────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_APPLICATION_ID=your-discord-application-id
# Optional: restrict to specific guild(s)
# DISCORD_GUILD_ID=11e68a7fd144266173a3ce0f432bc1f6ba3254beffac428053becf3daa147f44

# ── §8 网关运维 (Gateway) ───────────────────────────────────
# Gateway auth token (auto-generated if empty; keep secret!)
OPENCLAW_GATEWAY_TOKEN=ddbe345cd803cf17aab7842b8c02ee2ffaf459091d4fdf72
# Published ports (host side)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_WEB_PORT=18790

# ── §9 远程访问 (Tailscale, optional) ───────────────────────
# TAILSCALE_AUTHKEY=tskey-auth-xxx

# ── Misc ────────────────────────────────────────────────────
NODE_ENV=production
TZ=Asia/Hong_Kong

# ── §7 Calendar & Tasks ────────────────────────────────────
# Google account for gog (Gmail/Calendar/Drive)
# GOG_ACCOUNT=your@gmail.com

# Todoist API token (https://todoist.com/app/settings/integrations/developer)
# TODOIST_API_TOKEN=your-todoist-token

# Linear API key (Settings → API → Personal API Keys)
# LINEAR_API_KEY=lin_api_xxx

# ── §3 Private Document Assistant (Ollama) ──────────────────
# Ollama is auto-configured via Docker networking
OLLAMA_HOST=http://ollama:11434
OLLAMA_PORT=11434
