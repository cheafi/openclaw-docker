{
  "messages": {
    "ackReactionScope": "direct"
  },

  "agents": {
    "defaults": {
      "maxConcurrent": 4,
      "subagents": { "maxConcurrent": 8 },
      "compaction": { "mode": "safeguard" },
      "workspace": "/home/openclaw/.openclaw/workspace",
      "model": {
        "primary": "openai/gpt-5.2-pro"
      },
      "models": {
        "openai/gpt-5.2-pro": {},
        "anthropic/claude-sonnet-4": {},
        "openrouter/auto": {}
      }
    }
  },

  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token"
    },
    "port": 18789,
    "bind": "lan",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },

  "plugins": {
    "entries": {
      "discord": { "enabled": true },
      "whatsapp": { "enabled": false }
    }
  },

  "channels": {
    "discord": {
      "dmPolicy": "open",
      "groupPolicy": "open",
      "allowFrom": ["*"],
      "actions": {
        "reactions": true,
        "messages": true,
        "threads": true,
        "search": true,
        "polls": true,
        "stickers": true,
        "permissions": true,
        "memberInfo": true,
        "roleInfo": true,
        "channelInfo": true,
        "voiceStatus": true,
        "events": true,
        "emojiUploads": false,
        "stickerUploads": false,
        "roles": false,
        "moderation": false
      }
    }
  },

  "meta": {
    "lastTouchedVersion": "2026.3.24",
    "lastTouchedAt": "2026-03-24T00:00:00.000Z"
  }
}
