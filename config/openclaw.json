{
  "messages": {
    "ackReactionScope": "direct"
  },

  "agents": {
    "defaults": {
      "maxConcurrent": 4,
      "subagents": { "maxConcurrent": 8 },
      "compaction": { "mode": "safeguard" },
      "workspace": "/home/openclaw/.openclaw/workspace",
      "model": {
        "primary": "reelx/gpt-5.4"
      },
      "models": {
        "reelx/gpt-5.4": {},
        "reelx/gemini-3.1-pro-preview": {},
        "reelx/claude-sonnet-4-6": {}
      }
    }
  },

  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token"
    },
    "port": 18789,
    "bind": "lan",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },

  "plugins": {
    "entries": {
      "discord": { "enabled": true },
      "whatsapp": { "enabled": false }
    }
  },

  "channels": {
    "discord": {
      "dmPolicy": "open",
      "groupPolicy": "open",
      "streaming": "partial",
      "allowFrom": ["*"],
      "guilds": {
        "YOUR_GUILD_ID": {
          "requireMention": false
        }
      },
      "actions": {
        "reactions": true,
        "messages": true,
        "threads": true,
        "search": true,
        "polls": true,
        "stickers": true,
        "permissions": true,
        "memberInfo": true,
        "roleInfo": true,
        "channelInfo": true,
        "voiceStatus": true,
        "events": true,
        "emojiUploads": false,
        "stickerUploads": false,
        "roles": false,
        "moderation": false
      }
    }
  },

  "meta": {
    "lastTouchedVersion": "2026.3.24",
    "lastTouchedAt": "2026-03-24T00:00:00.000Z"
  },

  "models": {
    "providers": {
      "reelx": {
        "baseUrl": "https://reelxai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "gpt-5.4", "name": "GPT-5.4", "contextWindow": 128000, "reasoning": true },
          { "id": "gemini-3.1-pro-preview", "name": "Gemini 3.1 Pro", "contextWindow": 128000 },
          { "id": "claude-sonnet-4-6", "name": "Claude Sonnet 4.6", "contextWindow": 200000 }
        ]
      }
    }
  }
}
